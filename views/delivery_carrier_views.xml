<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inherit the delivery carrier form view and add a Stallion Express tab.
        Uses Odoo 17+ / 19+ invisible= syntax (not attrs=).
        xpath targets the first page/tab so we always insert after it even if
        the view changes between versions.
    -->
    <record id="view_delivery_carrier_form_stallion" model="ir.ui.view">
        <field name="name">delivery.carrier.form.stallion</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook/page[1]" position="after">
                <page string="Stallion Express"
                      name="stallion_express"
                      invisible="delivery_type != 'stallion_express'">

                    <group string="API Credentials">
                        <group>
                            <field name="stallion_api_token"
                                   password="True"
                                   placeholder="Paste your Bearer token here"/>
                            <field name="stallion_prod_environment"
                                   widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="stallion_store_id"
                                   placeholder="Optional — leave blank if not needed"/>
                            <button name="action_stallion_test_connection"
                                    string="Test Connection"
                                    type="object"
                                    class="btn-secondary mt-2"
                                    icon="fa-plug"/>
                        </group>
                    </group>

                    <group string="Shipping Options">
                        <group>
                            <field name="stallion_default_package_code"/>
                            <field name="stallion_default_weight_unit"/>
                            <field name="stallion_label_format"/>
                        </group>
                        <group>
                            <field name="stallion_signature_required" widget="boolean_toggle"/>
                            <field name="stallion_insurance" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <group string="Rate Markup (optional)">
                        <group>
                            <field name="stallion_markup_type"/>
                            <field name="stallion_markup_amount"/>
                        </group>
                    </group>

                    <div class="alert alert-info" role="alert">
                        <strong>Setup checklist:</strong>
                        <ol class="mb-0">
                            <li>Log in at <a href="https://stallionexpress.ca" target="_blank">stallionexpress.ca</a>
                                → <b>Account Settings → API Token</b> and copy your token.</li>
                            <li>Paste the token above, then click <b>Test Connection</b>.</li>
                            <li>Set <b>Integration Level</b> (top of the form) to
                                <b>Get Rate and Create Shipment</b>.</li>
                            <li>Toggle <b>Use Production API</b> on when ready to go live.</li>
                            <li>Click <b>Publish</b> (top of the form) to make this method
                                visible at checkout.</li>
                        </ol>
                    </div>

                </page>
            </xpath>

        </field>
    </record>

</odoo>
