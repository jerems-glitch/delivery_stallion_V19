<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_picking_form_stallion" model="ir.ui.view">
        <field name="name">stock.picking.form.stallion</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='carrier_tracking_ref']" position="after">
                <field name="stallion_shipment_id"
                       readonly="1"
                       invisible="not stallion_shipment_id"/>
                <field name="stallion_postage_code"
                       readonly="1"
                       invisible="not stallion_postage_code"/>
            </xpath>

        </field>
    </record>

</odoo>
